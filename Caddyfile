sky0cloud.dpdns.org {
    encode zstd gzip

    # Disable automatic HTTPS redirects (if needed)
    auto_https off

    # Matrix well-known
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
        header Content-Type "application/json; charset=utf-8"
        header Access-Control-Allow-Origin "*"
    }

    # Continuwuity API
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # Serve Element Web
    handle {
        root * /app
        try_files {path} /index.html
        file_server
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format console
    }

    # TLS email for certs (if you want HTTPS later)
    tls chapmlinks@gmail.com
}
