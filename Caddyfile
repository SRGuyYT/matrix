sky0cloud.dpdns.org {

    encode gzip zstd

    handle /_matrix/* {
        reverse_proxy sky0cloud-synapse:8008
    }

    handle /_synapse/* {
        reverse_proxy sky0cloud-synapse:8008
    }

    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}

matrix.sky0cloud.dpdns.org {
    reverse_proxy sky0cloud-synapse-admin:80
}
