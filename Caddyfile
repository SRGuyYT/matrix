{
    email chapmlinks@gmail.com
    auto_https off
}

# Main domain
sky0cloud.dpdns.org:80 {

    # Well-known for Matrix
    handle /.well-known/matrix/client {
        respond `{"m.homeserver": {"base_url": "https://sky0cloud.dpdns.org"}}` 200 {
            header Content-Type application/json
        }
    }

    handle /.well-known/matrix/server {
        respond `{"m.server": "sky0cloud.dpdns.org:443"}` 200 {
            header Content-Type application/json
        }
    }

    # Preflight CORS
    @preflight method OPTIONS
    handle @preflight {
        respond "" 204 {
            header Access-Control-Allow-Origin "https://admin.sky0cloud.dpdns.org"
            header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
            header Access-Control-Allow-Headers "Authorization, Content-Type, X-Matrix-User-ID"
            header Access-Control-Allow-Credentials "true"
        }
    }

    # Synapse API
    handle /_matrix/* {
        reverse_proxy sky0cloud-synapse:8008
        header Access-Control-Allow-Origin "https://admin.sky0cloud.dpdns.org"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, X-Matrix-User-ID"
        header Access-Control-Allow-Credentials "true"
    }

    handle /_synapse/admin/* {
        reverse_proxy sky0cloud-synapse:8008
        header Access-Control-Allow-Origin "https://admin.sky0cloud.dpdns.org"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, X-Matrix-User-ID"
        header Access-Control-Allow-Credentials "true"
    }

    # Serve Element Web
    handle {
        reverse_proxy sky0cloud-element-web:8080
    }
}

# Admin panel
admin.sky0cloud.dpdns.org:80 {
    reverse_proxy sky0cloud-synapse-admin:80 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}
