{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {
    encode zstd gzip

    # Discovery Headers for Matrix
    header /.well-known/matrix/* {
        Content-Type "application/json; charset=utf-8"
        Access-Control-Allow-Origin "*"
    }

    # Serve the static files from the volume
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
    }

    # Proxy to Conduwuit (Backend)
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # Proxy to Element (Frontend)
    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}
