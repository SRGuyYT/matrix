{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {
    encode zstd gzip

    # Set global headers for Matrix discovery
    header /.well-known/matrix/* {
        Content-Type "application/json; charset=utf-8"
        Access-Control-Allow-Origin "*"
    }

    # Serve the physical files you just pulled via git
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
    }

    # Matrix client-server API
    handle_path /_matrix/* {
        reverse_proxy continuwuity:6167
    }

    # Default (Element Web)
    handle {
        reverse_proxy element-web:80
    }
}
}
