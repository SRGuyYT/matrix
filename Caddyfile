{
    # Let Cloudflare handle TLS, no auto HTTPS needed
    auto_https off
}

# Admin panel subdomain
admin.sky0cloud.dpdns.org {
    reverse_proxy sky0cloud-synapse-admin:80
}

# Main homeserver domain
sky0cloud.dpdns.org {

    # Well-known endpoint for Matrix client auto-discovery
    handle /.well-known/matrix/client {
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
        header Content-Type application/json
    }

    # Well-known endpoint for Matrix server auto-discovery
    handle /.well-known/matrix/server {
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
        header Content-Type application/json
    }

    # Matrix API routing
    @matrix path /_matrix/*
    handle @matrix {
        reverse_proxy sky0cloud-synapse:8008

        # CORS headers for client connections
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers *
        header Access-Control-Expose-Headers "Authorization, Content-Type, Location"
        header Access-Control-Allow-Credentials true

        # Preflight OPTIONS handling
        respond * 204 {
            close
        }
    }

    # WebSocket support for Matrix
    @ws {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @ws {
        reverse_proxy sky0cloud-synapse:8008
    }

    # Everything else → Element Web
    reverse_proxy sky0cloud-element:80 {
        transport http {
            versions h2c 1.1
        }
    }
}
