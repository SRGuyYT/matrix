sky0cloud.dpdns.org {
    encode zstd gzip

    # Matrix discovery endpoint
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
        header Content-Type "application/json; charset=utf-8"
        header Access-Control-Allow-Origin "*"
    }

    # Continuwuity API
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # Element Web UI
    handle {
        root * /app  # serve Element's files properly
        try_files {path} /index.html
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format console
    }

    # TLS for HTTPS
    tls chapmlinks@gmail.com
}
