{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {
    encode zstd gzip

    # 1. Discovery Headers (Required for Element to find the server)
    header /.well-known/matrix/* {
        Content-Type "application/json; charset=utf-8"
        Access-Control-Allow-Origin "*"
    }

    # 2. Serve the static discovery files you pulled with git
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
    }

    # 3. Proxy to the Matrix Backend (Conduwuit)
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # 4. Proxy to the Element Web UI
    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}
