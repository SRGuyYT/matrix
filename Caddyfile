{
    email admin@sky0cloud.dpdns.org
    auto https off
}

# Main Matrix + Element endpoint
sky0cloud.dpdns.org {
    encode zstd gzip

    # CORS preflight for Matrix client/admin API calls.
    @matrix_preflight {
        method OPTIONS
        path /_matrix/* /_synapse/*
    }
    handle @matrix_preflight {
        header Access-Control-Allow-Origin "https://matrix.sky0cloud.dpdns.org"
        header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, Origin, User-Agent"
        header Access-Control-Max-Age "86400"
        respond "" 204
    }

    # Matrix Client + Federation + Synapse Admin API
    @matrix path /_matrix/* /_synapse/*
    handle @matrix {
        reverse_proxy http://sky0cloud-synapse:8008 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Prevent duplicate CORS headers from upstream.
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Allow-Methods
        }

        # Set one canonical CORS policy for admin panel cross-origin calls.
        header Access-Control-Allow-Origin "https://matrix.sky0cloud.dpdns.org"
        header Access-Control-Allow-Credentials "true"
        header Vary "Origin"
    }

    # Element web client
    handle {
        reverse_proxy http://sky0cloud-element-web:80
    }
}

# Synapse Admin panel endpoint
matrix.sky0cloud.dpdns.org {
    encode zstd gzip
    reverse_proxy http://sky0cloud-synapse-admin:80
}
