{
    email chapmlinks@gmail.com
    auto_https off
}

# Main domain (Element + Matrix API)
sky0cloud.dpdns.org:80 {

    # CORS headers
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Matrix-User-ID"
        Access-Control-Expose-Headers "Content-Length, X-Matrix-User-ID"
    }

    # Well-known for Matrix
    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{
            "m.homeserver": {
                "base_url": "https://sky0cloud.dpdns.org"
            }
        }` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{
            "m.server": "sky0cloud.dpdns.org:443"
        }` 200
    }

    # Synapse API routes
    @matrix path /_matrix/* /_synapse/*
    handle @matrix {
        reverse_proxy sky0cloud-synapse:8008
    }

    # Serve Element Web (including welcome.html)
    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}

admin.sky0cloud.dpdns.org:80 {
    reverse_proxy sky0cloud-synapse-admin:80 {
        header_up CF-Access-Client-Id "3ba6cbfd84bc38d308073186a1a7f538.access"
        header_up CF-Access-Client-Secret "598bf3224a1a07d6eb8da525a8e3773a2d6700594fe9ac35ba4fea78b113833b"
    }
}
