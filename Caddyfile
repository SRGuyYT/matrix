# Main Site: Matrix + Element Web
sky0cloud.dpdns.org:80 {
    # ------------------------------
    # 1. Matrix Discovery
    # ------------------------------
    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{
            "m.homeserver": {"base_url": "https://sky0cloud.dpdns.org"},
            "org.matrix.msc2965.authentication": {
                "issuer": "https://sky0cloud.dpdns.org/",
                "account": "https://sky0cloud.dpdns.org/account"
            }
        }` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    # ------------------------------
    # 2. MAS Traffic (FIXED MATCHER)
    # ------------------------------
    @mas_paths path /auth/* /account/* /re-auth/* /.well-known/openid-configuration
    handle @mas_paths {
        reverse_proxy http://sky0cloud-mas:8080 {
            header_up X-Forwarded-For {header.Cf-Connecting-Ip}
        }
    }

    # ------------------------------
    # 3. Matrix API (Synapse - FIXED MATCHER)
    # ------------------------------
    @synapse_paths path /_matrix/* /_synapse/*
    handle @synapse_paths {
        reverse_proxy http://sky0cloud-synapse:8008 {
            header_up X-Forwarded-For {header.Cf-Connecting-Ip}
            
            # CORS fix
            header_down -Access-Control-Allow-Origin
            header_down Access-Control-Allow-Origin "*"
        }
    }

    # ------------------------------
    # 4. Element Web Client
    # ------------------------------
    handle {
        reverse_proxy http://sky0cloud-element-web:80
    }
}

# Synapse Admin UI
matrix.sky0cloud.dpdns.org:80 {
    reverse_proxy http://sky0cloud-synapse-admin:80
}
