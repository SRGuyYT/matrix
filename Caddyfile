{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {

    # Matrix federation discovery
    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    # Matrix client discovery
    handle /.well-known/matrix/client {
        header Access-Control-Allow-Origin *
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # Matrix API + Media
    handle /_matrix/* {
        reverse_proxy http://sky0cloud-continuwuity:6167 {
            header_up Host sky0cloud.dpdns.org
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {remote}
        }
    }

    # Element Web Client
    handle {
        reverse_proxy http://element-web:80
    }

    # CORS headers (helps media loading)
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
        Access-Control-Allow-Headers *
    }
}
