{
    email chapmlinks@gmail.com
}

sky0cloud.dpdns.org {
    encode zstd gzip

    # Matrix discovery endpoint
    handle /.well-known/matrix/* {
        root * /var/www/matrix
        file_server
        header Content-Type "application/json; charset=utf-8"
        header Access-Control-Allow-Origin "*"
    }

    # Continuwuity API
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # Element Web UI
    handle {
        reverse_proxy sky0cloud-element-web:80
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format console
    }

    # TLS (HTTPS) automatically enabled
    tls chapmlinks@gmail.com
}
