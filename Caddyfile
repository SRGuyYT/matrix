{
    email chapmlinks@gmail.com
    auto_https off
}

# Synapse Admin UI
admin.sky0cloud.dpdns.org {
    reverse_proxy synapse-admin:80
}

# Main domain (Element + Matrix)
sky0cloud.dpdns.org {

    # Matrix discovery
    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}`
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:443"}`
    }

    # Matrix API
    @matrix path /_matrix/* /_synapse/*

    reverse_proxy @matrix synapse:8008 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # Element Web
    reverse_proxy element:80
}
