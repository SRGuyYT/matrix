{
    email chapmlinks@gmail.com
    auto_https off
}

admin.sky0cloud.dpdns.org {
    reverse_proxy sky0cloud-synapse-admin:80
}

sky0cloud.dpdns.org {

    # --- CORS ---
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Matrix-User-ID"
        Access-Control-Expose-Headers "Content-Length, X-Matrix-User-ID"
    }

    # --- Well-known: Client ---
    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{
            "m.homeserver": {
                "base_url": "https://sky0cloud.dpdns.org"
            }
        }` 200
    }

    # --- Well-known: Server ---
    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{
            "m.server": "sky0cloud.dpdns.org:443"
        }` 200
    }

    # --- Matrix API routing ---
    @matrix path /_matrix/* /_synapse/* /_admin/*
    handle @matrix {
        reverse_proxy sky0cloud-synapse:8008 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # --- Everything else → Element Web ---
    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}
