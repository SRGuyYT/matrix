{
    auto_https off
}

# Admin panel
admin.sky0cloud.dpdns.org {
    reverse_proxy sky0cloud-synapse-admin:8080
}

# Main domain
sky0cloud.dpdns.org {

    # Well-known client discovery
    handle /.well-known/matrix/client {
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
        header Content-Type application/json
    }

    # Well-known server discovery
    handle /.well-known/matrix/server {
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
        header Content-Type application/json
    }

    # Matrix API and federation endpoints
    @matrix path /_matrix/* /_synapse/*
    handle @matrix {
        reverse_proxy sky0cloud-synapse:8008
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers *
    }

    # TURN/STUN endpoints (optional if accessed via WebRTC directly)
    @turn path /turn
    handle @turn {
        reverse_proxy coturn.sky0cloud.dpdns.org:3478
    }

    # Everything else → Element Web
    reverse_proxy sky0cloud-element:80
}
