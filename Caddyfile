{
    email chapmlinks@gmail.com
    auto_https off
}

# Synapse Admin UI
matrix.sky0cloud.dpdns.org:80 {
    reverse_proxy sky0cloud-synapse-admin:80
}

# Matrix federation endpoint
sky0cloud.dpdns.org:8448 {
    reverse_proxy sky0cloud-synapse:8008
}

# Main site: Element + Matrix
sky0cloud.dpdns.org:80 {

    # Global CORS policy (kept exactly like you wanted)
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Matrix-User-ID"
        Access-Control-Expose-Headers "Content-Length, X-Matrix-User-ID"
    }

    # Matrix discovery
    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:8448"}` 200
    }

    # Matrix API routes
    @synapse_paths path /_matrix/* /_synapse/* /_admin/*
    handle @synapse_paths {
        reverse_proxy http://sky0cloud-synapse:8008 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}

            # prevent duplicate CORS headers from Synapse
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Methods
            header_down -Access-Control-Allow-Headers
        }
    }

    # Element web client
    handle {
        reverse_proxy http://sky0cloud-element-web:80
    }
}
