{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {
    encode zstd gzip

    # .well-known client discovery
    @wellknownClient path /.well-known/matrix/client
    handle @wellknownClient {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond 200 '{"m.homeserver":{"base_url":"http://sky0cloud.dpdns.org"}}'
    }

    # .well-known server discovery
    @wellknownServer path /.well-known/matrix/server
    handle @wellknownServer {
        header Content-Type application/json
        respond 200 '{"m.server":"sky0cloud.dpdns.org:80"}'
    }

    # Matrix API proxy
    handle_path /_matrix/* {
        reverse_proxy sky0cloud-continuwuity:6167
    }

    # Catch-all → Element Web
    handle {
        reverse_proxy sky0cloud-element-web:80
    }
}
