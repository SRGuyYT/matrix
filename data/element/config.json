      "base_url": "https://sky0cloud.dpdns.org",
      "server_name": "sky0cloud.dpdns.org"
    },
    "m.identity_server": {
      "base_url": "https://vector.im"
    }
  },

  "branding": {
    "authHeaderLogoUrl": "icon.png",
    "welcomeBackgroundUrl": "background.jpg",
    "welcomeHeader": "Welcome to Sky0Cloud",
